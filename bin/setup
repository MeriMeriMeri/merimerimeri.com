#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

require_command() {
  local command_name="$1"
  local install_hint="$2"

  if ! command -v "$command_name" >/dev/null 2>&1; then
    echo "Missing required command: $command_name"
    echo "$install_hint"
    exit 1
  fi
}

require_command "ruby" "Install Ruby 3.3.x before running this setup script."
require_command "gem" "Install RubyGems before running this setup script."
require_command "npm" "Install Node.js/npm before running this setup script."

GEM_USER_BIN_DIR="$(ruby -r rubygems -e 'print File.join(Gem.user_dir, "bin")')"
export PATH="$GEM_USER_BIN_DIR:$PATH"

if ! command -v bundle >/dev/null 2>&1; then
  echo "Bundler not found. Installing it with RubyGems in your user gem directory..."
  gem install --user-install bundler
  hash -r
fi

echo "Installing Ruby gems..."
bundle install

echo "Installing Node packages..."
if [[ -f package-lock.json ]]; then
  npm ci
else
  npm install
fi

echo
echo "Setup complete."
echo "Start the site with: bundle exec jekyll serve"
